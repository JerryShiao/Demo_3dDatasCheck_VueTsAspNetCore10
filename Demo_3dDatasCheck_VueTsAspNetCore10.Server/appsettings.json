{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  /* 建物異常檢測閾值設定 */
  "BuildingAbnormalDetection": {
    "GroundFloorBottomThreshold": 5.0, // 一般 1 樓底部離地容許上限（疑似浮空）
    "FloorGapTolerance": 0.5,          // 相鄰樓層垂直重疊容許量
    "MaxFloorGap": 3.0,                // 相鄰樓層垂直斷層落差上限
    "MinFloorHeight": 2.0,             // 單層高度下限
    "MaxFloorHeight": 8.0              // 單層高度上限
  },
  /* CityDoctor2 CityGML 拓撲預處理設定 */
  "CityDoctor2": {
    "Enabled": false,
    "ExecutablePath": "",
    "ValidationPlanPath": "",
    "WorkingDirectory": "",
    "TimeoutSeconds": 60,
    "KeepArtifacts": false
  },
  /* ModelOfBuilding_WebAPI ConsistsOfBuildingParts 寫回設定 */
  "ModelOfBuildingApi": {
    "ConsistsOfBuildingPartsUrl": "http://localhost:240/api/ConsistsOfBuildingParts"
  }
}
